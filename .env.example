# Firebase — same project as your ILYTAT Hub
# Copy these from hub/.env (or Firebase console > Project settings)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Hub URL — the deployed Hub domain (used for auth redirects and "Back to Hub" link)
# Local: http://localhost:3000
# Production: https://your-hub.vercel.app
NUXT_PUBLIC_HUB_URL=http://localhost:3000
